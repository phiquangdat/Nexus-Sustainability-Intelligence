# Frontend Environment Variables
# Copy this file to .env.local for local development
# Integrates Python environment variables into React/Vite

# Supabase Configuration (from Python .env)
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Data Source Configuration
VITE_DEFAULT_DATA_SOURCE=simulated
VITE_AUTO_REFRESH_ENABLED=true
VITE_REFRESH_INTERVAL=30000

# Simulator Configuration (from Python simulator/config.py)
VITE_SIM_TIMEZONE=UTC
VITE_SIM_WALL_INTERVAL_SECONDS=5
VITE_SIM_STEP_MINUTES=15
VITE_SIM_RANDOM_SEED=

# Output Configuration
VITE_OUTPUT_MODE=csv
VITE_CSV_OUTPUT_DIR=data

# Table Names (from Python simulator/config.py)
VITE_TABLE_CO2_INTENSITY=co2_intensity
VITE_TABLE_GENERATION_MIX=generation_mix
VITE_TABLE_NETZERO_ALIGNMENT=netzero_alignment

# Development Configuration
VITE_ENABLE_LOGGING=true
VITE_ENABLE_DEBUG_MODE=false

# API Configuration
VITE_API_BASE_URL=http://localhost:4000
VITE_API_TIMEOUT=30000

# Chart Configuration
VITE_CHART_ANIMATION_ENABLED=true
VITE_CHART_RESPONSIVE_ENABLED=true

# Real-time Configuration
VITE_REALTIME_ENABLED=true
VITE_REALTIME_RECONNECT_INTERVAL=5000
